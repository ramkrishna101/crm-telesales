# ── Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in all values before starting.

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://crm_user:crm_pass@localhost:5435/crm_db"
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_pass
POSTGRES_DB=crm_db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT (generate secure random strings in production) ────────────────
# openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── File Uploads ──────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Telephony (integrate real provider in Phase 5) ────────────────────
# stub | exotel | twilio | ozonetel
TELEPHONY_PROVIDER=stub
# EXOTEL_API_KEY=
# EXOTEL_API_TOKEN=
# EXOTEL_SID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
