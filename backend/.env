# Environment Variables — copy to .env and fill in secrets

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://crm_user:crm_pass@localhost:5435/crm_db

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Telephony ────────────────────────────────────────────
# Options: stub | exotel | mcube | twilio
TELEPHONY_PROVIDER=stub
# Exotel (fill when ready)
# EXOTEL_SID=
# EXOTEL_TOKEN=
# EXOTEL_FROM_NUMBER=

# ── File Upload ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Frontend ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
